---
import LinkCard from "./card/LinkCard.astro";
import Piktogram from "./Piktogram.astro";
import styles from "./Komponent.module.css";
import { BodyLong, Heading } from "@navikt/ds-react";

const { heading, description, cvUrl } = Astro.props;
---

<LinkCard href={cvUrl}>
  <div class={styles.komponentContainer}>
    <div>
      <Piktogram />
    </div>
    <div>
      <Heading size="small" className={styles.heading}>{heading}</Heading>
      <BodyLong size="medium" className={styles.detail}>{description}</BodyLong>
    </div>
  </div>
</LinkCard>
