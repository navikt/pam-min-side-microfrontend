---
import { text } from "@src/language/text";
import type { Language } from "@src/language/types";
import styles from "@src/styles/index.module.css";
import "@src/styles/aksel.css";
import { getEnvironment, isLocal } from "../../utils/environment";
import Komponent from "@src/components/Komponent.astro";
import { cvUrl } from "@src/utils/cvUrl.ts";

const language = Astro.currentLocale as Language;
const currentLocation = Astro.url.href as string;
const environment = getEnvironment(currentLocation)
---

{isLocal &&
<meta charset="UTF-8" />}
<section class="pam-min-side-microfrontend">
  <div class={styles.microfrontend}>
    <Komponent heading={text.title[language]} description={text.description[language]} cvUrl={cvUrl(environment)}/>
  </div>
</section>
<script>
  import { logEvent } from "@src/utils/analytics";

  const microfrontend = document.querySelector("#link");
  microfrontend?.addEventListener("click", () => logEvent("Lenke"));
</script>
